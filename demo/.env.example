# Azure AI Foundry 프로젝트 엔드포인트 (필수)
FOUNDRY_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project-id

# 배포된 모델 이름 (선택, 기본값: gpt-5.4-2)
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-5.4-2

# Foundry IQ — Knowledge Base (RAG 시나리오 1, 3 사용 시 필수 — 미설정 시 MCP 시나리오만 동작)
# AI Foundry 포털에서 생성한 Knowledge Base 이름
KNOWLEDGE_BASE_NAME=company-docs-kb
